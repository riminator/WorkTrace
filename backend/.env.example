DATABASE_URL=postgresql://kb_user:kb_pass@localhost:5432/knowledge_base
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Dimensions must match the chosen model:
#   nomic-embed-text  -> 768
#   mxbai-embed-large -> 1024
#   all-minilm        -> 384
EMBED_DIMENSIONS=768

# ── Time Task Tracker integration ─────────────────────────────────────────────
# Neon (or any Postgres) connection string for the TTT database
TTT_DATABASE_URL=postgresql://user:pass@host/timetasktracker?sslmode=require
# SSL required for Neon
TTT_PGSSL=true
