# ── Vector DB (Supabase or any PostgreSQL + pgvector) ─────────────────────────
# Get this from: Supabase dashboard → Project Settings → Database → Connection string
# Use the "Session pooler" URI (port 5432) for compatibility with pgvector
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Get both from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://iauelxumvcwsndypnmhb.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBED_PROVIDER: "ollama" (local) | "nomic" (cloud, free)
EMBED_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Dimensions must match the chosen model:
#   nomic-embed-text  -> 768
#   mxbai-embed-large -> 1024
#   all-minilm        -> 384
EMBED_DIMENSIONS=768

# ── LLM ───────────────────────────────────────────────────────────────────────
# LLM_PROVIDER: "ollama" (local) | "openai" (Groq/OpenAI/etc.) | "watsonx"
LLM_PROVIDER=ollama
# For Groq (free):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_CHAT_MODEL=llama-3.1-8b-instant

# ── Time Task Tracker integration ─────────────────────────────────────────────
# Supabase connection string for the TTT database (can be same project, different schema)
TTT_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
TTT_PGSSL=true
