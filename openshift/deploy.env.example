# openshift/deploy.env.example
# Copy this to openshift/deploy.env and fill in your values.
# deploy.env is gitignored — never commit it.
#
#   cp openshift/deploy.env.example openshift/deploy.env
#   nano openshift/deploy.env        # fill in values
#   ./openshift/deploy.sh            # run the script

# ── Quay.io image registry ────────────────────────────────────────────────────
REGISTRY=quay.io/akshaymallibm

# ── OpenShift cluster login ───────────────────────────────────────────────────
# Get from: OCP console → top-right menu → "Copy login command"
OC_SERVER=https://api.your-cluster.com:6443
OC_TOKEN=your-oc-login-token
OC_PROJECT=knowledgebase

# ── Supabase (frontend build args — baked into the JS bundle) ─────────────────
# Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# ── In-cluster Postgres password ─────────────────────────────────────────────
# This is used to create the postgres-credentials secret in the cluster.
# DATABASE_URL is auto-built from this — no need to set it manually.
POSTGRES_PASSWORD=choose-a-strong-password-here

# ── Supabase Auth (auth only — Postgres is now in-cluster) ───────────────────
# Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Embeddings
EMBED_PROVIDER=nomic
NOMIC_API_KEY=your-nomic-api-key
NOMIC_EMBED_MODEL=nomic-embed-text-v1.5
EMBED_DIMENSIONS=768

# LLM
LLM_PROVIDER=watsonx
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_MODEL_ID=ibm/granite-4-h-small

# RAG
RAG_TOP_K=5
