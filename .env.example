## ─────────────────────────────────────────────────────────────
##  KnowledgeBase — Environment Configuration
##  Copy this file to .env and fill in the values.
##
##  Suggested setup for confidential cloud use:
##    - Keep embeddings on Nomic cloud
##    - Use watsonx.ai for LLM/chat
##
##  Easy rollback:
##    - Keep the Groq block filled in but commented out
##    - Switch only LLM_PROVIDER and the matching provider block
## ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local Docker pgvector:
DATABASE_URL=postgresql://postgres:password@localhost:5433/vector
# Cloud (Neon) — uncomment and fill in:
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ── Embeddings ────────────────────────────────────────────────
# Default cloud embedding setup used by this project.
EMBED_DIMENSIONS=768
EMBED_PROVIDER=nomic
NOMIC_API_KEY=your_nomic_api_key_here
NOMIC_EMBED_MODEL=nomic-embed-text-v1.5

# Local embedding fallback (comment cloud values above and uncomment below)
# EMBED_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ── LLM / Chat ────────────────────────────────────────────────
## ACTIVE PRESET: watsonx.ai
LLM_PROVIDER=watsonx
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=9cba7106-08fc-4e22-b08e-308567a7c062
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

## ROLLBACK PRESET: Groq — keep this block commented for easy fallback
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_groq_api_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_CHAT_MODEL=llama-3.1-8b-instant

## Local fallback
# LLM_PROVIDER=ollama
# OLLAMA_CHAT_MODEL=llama3.2

# ── RAG settings ──────────────────────────────────────────────
RAG_TOP_K=5

# ── Time Task Tracker integration ─────────────────────────────
# Neon connection string for the TTT database
TTT_DATABASE_URL=postgresql://user:pass@host.neon.tech/timetasktracker?sslmode=require
TTT_PGSSL=true
