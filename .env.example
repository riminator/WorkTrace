## ─────────────────────────────────────────────────────────────
##  KnowledgeBase — Environment Configuration
##  Copy this file to .env and fill in the values.
##
##  Two presets below:
##    LOCAL  — Ollama for both embeddings and LLM (no API keys needed)
##    CLOUD  — Zhipu AI (z.ai) for both embeddings and LLM (free tier)
## ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local Docker pgvector:
DATABASE_URL=postgresql://postgres:password@localhost:5433/vector
# Cloud (Neon) — uncomment and fill in:
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ── Embeddings ────────────────────────────────────────────────
# Dimensions must match the active embed model:
#   nomic-embed-text (Ollama) → 768
#   embedding-3 (Zhipu)       → 768  (dimensions param is passed automatically)
EMBED_DIMENSIONS=768

## PRESET: LOCAL (Ollama)
EMBED_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

## PRESET: CLOUD (Zhipu) — comment out LOCAL block above and uncomment below
# EMBED_PROVIDER=zhipu
# ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_EMBED_MODEL=embedding-3

# ── LLM / Chat ────────────────────────────────────────────────
## PRESET: LOCAL (Ollama llama3.2)
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3.2

## PRESET: CLOUD (Zhipu GLM-4 Flash — free) — comment out LOCAL block above and uncomment below
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_zhipu_api_key_here
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_CHAT_MODEL=glm-4-flash

# ── RAG settings ──────────────────────────────────────────────
RAG_TOP_K=5

# ── Time Task Tracker integration ─────────────────────────────
# Neon connection string for the TTT database
TTT_DATABASE_URL=postgresql://user:pass@host.neon.tech/timetasktracker?sslmode=require
TTT_PGSSL=true
